# 微信运动打卡小程序 - .gitignore

# 依赖
node_modules/
miniprogram_npm/

# 环境配置
server/.env

# 编译输出
dist/
build/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志
logs/
*.log
npm-debug.log*

# 临时文件
tmp/
temp/
.cache/

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 锁文件
package-lock.json
yarn.lock

# 测试
coverage/
.nyc_output/
