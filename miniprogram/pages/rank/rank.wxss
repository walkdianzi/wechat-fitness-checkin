/* pages/rank/rank.wxss */
.container {
  padding-bottom: 40rpx;
  background: #f5f5f5;
}

/* 我的排名卡片 */
.my-rank-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
}

.rank-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.rank-title {
  font-size: 32rpx;
  font-weight: 600;
}

.rank-period {
  font-size: 24rpx;
  opacity: 0.9;
}

.my-rank-body {
  gap: 30rpx;
}

.rank-number {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.rank-number.top {
  background: rgba(255,255,255,0.3);
  border-color: #FFD700;
}

.num {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.rank-info {
  display: flex;
  flex-direction: column;
}

.rank-desc {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.rank-steps {
  font-size: 40rpx;
  font-weight: 600;
}

/* 排行类型切换 */
.rank-tabs {
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
}

.rank-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.rank-tab.active {
  background: #4CAF50;
  color: #fff;
}

/* 排行榜列表 */
.rank-list {
  margin-top: 20rpx;
}

.rank-item {
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rank-index {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}

.rank-index.top {
  background: linear-gradient(135deg, #FFD700, #FFC107);
  color: #fff;
}

.index-num {
  line-height: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eee;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.user-stat {
  font-size: 26rpx;
  color: #999;
}

.rank-medal {
  font-size: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-text {
  font-size: 28rpx;
  color: #999;
}
