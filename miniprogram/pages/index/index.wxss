/* pages/index/index.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.user-info {
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.welcome {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}

/* 登录卡片 */
.login-card {
  text-align: center;
  padding: 60rpx 30rpx;
}

.login-text {
  font-size: 32rpx;
  color: #666;
}

/* 步数卡片 */
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.steps-display {
  flex-direction: column;
  padding: 40rpx 0;
}

.steps-count {
  font-size: 120rpx;
  font-weight: 700;
  color: #4CAF50;
  line-height: 1;
}

.steps-unit {
  font-size: 32rpx;
  color: #999;
  margin-top: 16rpx;
}

.steps-sync {
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.sync-time {
  font-size: 24rpx;
  color: #999;
}

.btn-sync {
  background: #4CAF50;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 28rpx;
  border: none;
}

.btn-sync:active {
  opacity: 0.8;
}

/* 快捷操作 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.action-item:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 小贴士 */
.tip-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #4CAF50;
}
