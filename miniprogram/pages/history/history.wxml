<!--pages/history/history.wxml-->
<view class="container">
  <!-- 统计概览 -->
  <view class="stats-card card">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{totalDays}}</text>
        <text class="stat-label">累计打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{continuousDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{totalSteps}}</text>
        <text class="stat-label">总步数</text>
      </view>
    </view>
  </view>

  <!-- 日期筛选 -->
  <view class="filter-card card">
    <view class="filter-tabs">
      <view 
        class="filter-tab {{filterType === 'week' ? 'active' : ''}}" 
        bindtap="setFilter"
        data-type="week"
      >
        本周
      </view>
      <view 
        class="filter-tab {{filterType === 'month' ? 'active' : ''}}" 
        bindtap="setFilter"
        data-type="month"
      >
        本月
      </view>
      <view 
        class="filter-tab {{filterType === 'all' ? 'active' : ''}}" 
        bindtap="setFilter"
        data-type="all"
      >
        全部
      </view>
    </view>
  </view>

  <!-- 打卡列表 -->
  <view class="history-list">
    <view 
      class="history-item card" 
      wx:for="{{historyList}}" 
      wx:key="id"
    >
      <view class="item-header flex-between">
        <view class="item-date">
          <text class="date-main">{{item.dateStr}}</text>
          <text class="date-week">{{item.weekDay}}</text>
        </view>
        <view class="item-mood">{{item.mood}}</view>
      </view>
      
      <view class="item-body">
        <view class="item-steps">
          <text class="steps-num">{{item.stepCount}}</text>
          <text class="steps-unit">步</text>
        </view>
        <view class="item-stats">
          <text class="stat-text">📍 {{item.distance}}km</text>
          <text class="stat-text">🔥 {{item.calorie}}kcal</text>
        </view>
      </view>

      <view class="item-footer" wx:if="{{item.note}}">
        <text class="item-note">{{item.note}}</text>
      </view>

      <view class="item-status">
        <text class="status-badge {{item.isCheckedIn ? 'success' : 'missed'}}">
          {{item.isCheckedIn ? '已打卡' : '未打卡'}}
        </text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{historyList.length === 0}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无打卡记录</text>
      <text class="empty-hint">快去运动打卡吧~</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text class="load-text">加载更多</text>
  </view>
</view>
