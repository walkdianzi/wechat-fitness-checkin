/* pages/history/history.wxss */
.container {
  padding-bottom: 40rpx;
  background: #f5f5f5;
}

/* 统计卡片 */
.stats-card {
  padding: 0;
  overflow: hidden;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4CAF50;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 筛选卡片 */
.filter-card {
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-tab.active {
  background: #4CAF50;
  color: #fff;
}

/* 历史列表 */
.history-list {
  margin-top: 20rpx;
}

.history-item {
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.item-header {
  margin-bottom: 24rpx;
}

.item-date {
  display: flex;
  flex-direction: column;
}

.date-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.date-week {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.item-mood {
  font-size: 40rpx;
}

.item-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-steps {
  display: flex;
  align-items: baseline;
}

.steps-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #4CAF50;
  line-height: 1;
}

.steps-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.item-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #666;
}

.item-footer {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.item-note {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.item-status {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.success {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-badge.missed {
  background: #FFEBEE;
  color: #F44336;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-text {
  font-size: 28rpx;
  color: #999;
}
